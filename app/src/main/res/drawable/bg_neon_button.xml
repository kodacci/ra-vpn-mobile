<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed: solid neon fill -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/neon_magenta" />
            <stroke android:width="2dp" android:color="@color/neon_cyan" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Disabled: dimmed -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/cyber_surface" />
            <stroke android:width="1dp" android:color="@color/cyber_hint" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Default: neon outline on dark -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#33FF2A6D" />
            <stroke android:width="2dp" android:color="@color/neon_magenta" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</selector>
